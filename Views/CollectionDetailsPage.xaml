<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CollectionManagementSystem.Models"
             x:Class="CollectionManagementSystem.Views.CollectionDetailsPage"
             Title="{Binding Name}"
             BackgroundColor="#FAF4ED">

    <Grid RowDefinitions="Auto, Auto, *">
        <HorizontalStackLayout Grid.Row="0" Margin="10" Spacing="10" HorizontalOptions="Center">
            <Button Text="Dodaj element" Clicked="OnAddItemClicked" BackgroundColor="#2B303A" TextColor="#92DCE5" CornerRadius="8"/>
            <Button Text="Dodaj kolumne" Clicked="OnAddColumnClicked" BackgroundColor="#7C7C7C" TextColor="White" CornerRadius="8"/>
        </HorizontalStackLayout>

        <ScrollView Grid.Row="1" Orientation="Horizontal" Margin="10,0">
            <StackLayout x:Name="TableHeader" Orientation="Horizontal" Spacing="10">
                
            </StackLayout>
        </ScrollView>

        <ScrollView Grid.Row="2" Margin="10">
            <StackLayout x:Name="TableData" Spacing="5">
                
            </StackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
